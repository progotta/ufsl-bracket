{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install --legacy-peer-deps",
  "devCommand": "npm run dev",
  "crons": [
    {
      "path": "/api/cron/achievements",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/sync-scores",
      "schedule": "*/5 * * * *"
    }
  ]
}
