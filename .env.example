# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase direct DB URL — use the Connection Pooling URL (port 6543) for serverless
# Dashboard → Settings → Database → Connection pooling → URI
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[pass]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Site URL (for OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# The Odds API (https://the-odds-api.com) - free tier available
# Used for live betting lines / spreads / moneylines
# Leave unset to use mock data
ODDS_API_KEY=

# OpenAI API Key — used for bracket screenshot import (GPT-4 Vision)
# Get one at: https://platform.openai.com/api-keys
# Required for the "Import Bracket" feature (upload ESPN/Yahoo/CBS/NCAA screenshots)
ANTHROPIC_API_KEY=

# Web Push / VAPID Keys — required for push notifications
# Generate with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
# Or: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# Internal secret for the /api/notifications/send endpoint (prevent public abuse)
# Generate with: openssl rand -hex 32
NOTIFICATION_SECRET=your_random_secret_here

# Admin user IDs — comma-separated Supabase user UUIDs that can access /admin/* routes
# Find your user ID in Supabase Dashboard → Authentication → Users
# Example: ADMIN_USER_IDS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx,yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy
ADMIN_USER_IDS=

# Upstash Redis — free tier available at https://upstash.com
# Enables cross-instance caching for live scores, leaderboards, and team data
# Without this, caching is in-memory only (per serverless instance)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
